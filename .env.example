# Copy this file to `.env` and fill in. NEVER commit a real `.env`.

# ----- demo ChatBot (mocked in /api/chat) -----
# You do NOT need a real provider to run the demo. The /api/chat route
# returns canned replies based on keyword matching.

# OpenAI (optional; only if you later swap the mock provider)
# OPENAI_API_KEY=sk-replace-me
# OPENAI_MODEL=gpt-4o-mini

# ----- audit CLI -----
# Nothing required; the audit tool has zero runtime dependencies.
# CI may set:
# GITHUB_TOKEN=...   # only if you want the audit to call GitHub API
